BACKEND_PORT=8000
FRONTEND_PORT=5173
RUNNER_PORT=8100

# Backend data storage. Default uses SQLite inside the backend_data volume.
DATABASE_URL=sqlite:////app/data/app.db

# Android Playground usually runs on the host because it needs adb/device access.
MIDSCENE_BASE_URL=http://host.docker.internal:5800
ANDROID_PLAYGROUND_URL=http://localhost:5800
API_BASE_URL=/api

# Optional model config
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL_NAME=
MIDSCENE_MODEL_BASE_URL=
MIDSCENE_MODEL_API_KEY=
MIDSCENE_MODEL_NAME=
MIDSCENE_MODEL_FAMILY=
