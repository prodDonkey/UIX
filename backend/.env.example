APP_NAME=UI自动化脚本 API
APP_ENV=dev
DATABASE_URL=sqlite:///./app.db
RUN_SCRIPTS_DIR=./runtime/scripts
RUN_LOGS_DIR=./runtime/logs
RUN_COMMAND_PREFIX=npx midscene
REPORT_ROOT_DIR=./midscene_run/report
# YAML 生成接口优先使用 LLM_*，未配置时回退到 MIDSCENE_*
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL_NAME=
LLM_GENERATION_SYSTEM_PROMPT=
LLM_GENERATION_SYSTEM_PROMPT_FILE=./prompts/yaml_system_prompt.txt
MIDSCENE_MODEL_BASE_URL=
MIDSCENE_MODEL_API_KEY=
MIDSCENE_MODEL_NAME=
MIDSCENE_MODEL_FAMILY=
LLM_TIMEOUT_SEC=60
