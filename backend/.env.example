APP_NAME=UI自动化脚本 API
APP_ENV=dev
# SQLite (default for local dev)
# DATABASE_URL=sqlite:///./app.db
# MySQL example
DATABASE_URL=mysql+pymysql://root:password@123.56.42.149:3306/ui_demo?charset=utf8mb4
RUN_SCRIPTS_DIR=./runtime/scripts
RUN_LOGS_DIR=./runtime/logs
RUN_COMMAND_PREFIX=npx midscene
RUNNER_BASE_URL=http://127.0.0.1:8100
RUNNER_TIMEOUT_SEC=10
RUNNER_PROGRESS_POLL_INTERVAL_MS=1000
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT_SEC=30
REPORT_ROOT_DIR=./midscene_run/report
# YAML 生成接口优先使用 LLM_*，未配置时回退到 MIDSCENE_*
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL_NAME=
LLM_GENERATION_SYSTEM_PROMPT=
LLM_GENERATION_SYSTEM_PROMPT_FILE=./prompts/yaml_system_prompt.txt
MIDSCENE_MODEL_BASE_URL=
MIDSCENE_MODEL_API_KEY=
MIDSCENE_MODEL_NAME=
MIDSCENE_MODEL_FAMILY=
LLM_TIMEOUT_SEC=60
